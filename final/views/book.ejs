<%- include('partials/nav', { title: 'Book Appointment', page: 'book' }) %>
<div class="page-banner">
  <h1>Book Appointment</h1>
  <p>Schedule your measurement session</p>
  <div class="breadcrumb"><a href="/">Home</a> › Book Appointment</div>
</div>
<section class="form-section" style="padding: 80px 5%;">
  <div class="form-card">
    <h2 style="font-family:'Playfair Display',serif; font-size:28px; margin-bottom:8px;">Schedule a Visit</h2>
    <p style="color:var(--text-light); margin-bottom:32px; font-size:15px;">We'll confirm your appointment via phone or WhatsApp within 2 hours.</p>
    <% if (success) { %><div class="alert-success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert-error"><%= error %></div><% } %>
    <% if (!success) { %>
    <form method="POST" action="/book">
      <div class="form-row">
        <div class="form-group"><label>Full Name *</label><input name="customerName" required placeholder="Your name"></div>
        <div class="form-group"><label>Phone *</label><input name="phone" required placeholder="9876543210"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Email</label><input name="email" type="email" placeholder="your@email.com"></div>
        <div class="form-group">
          <label>Service *</label>
          <select name="service" required>
            <option value="">Select a service</option>
            <option>Custom Tailoring</option>
            <option>Women's Wear</option>
            <option>Alterations & Repairs</option>
            <option>Uniform / Bulk Order</option>
            <option>Fabric Selection</option>
            <option>Bridal Consultation</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Preferred Date *</label><input name="date" type="date" required min="<%= new Date().toISOString().split('T')[0] %>"></div>
        <div class="form-group">
          <label>Preferred Time *</label>
          <select name="time" required>
            <option value="">Select time</option>
            <option>09:00</option><option>10:00</option><option>11:00</option>
            <option>12:00</option><option>14:00</option><option>15:00</option>
            <option>16:00</option><option>17:00</option><option>18:00</option>
            <option>19:00</option>
          </select>
        </div>
      </div>
      <div class="form-group full"><label>Notes / Special Requirements</label><textarea name="notes" rows="3" placeholder="Describe your requirement, occasion, preferences..."></textarea></div>
      <button type="submit" class="btn-primary" style="width:100%; justify-content:center; padding:16px; font-size:16px;">✓ Confirm Appointment</button>
    </form>
    <% } else { %>
    <div style="text-align:center; padding:20px 0;">
      <div style="font-size:64px; margin-bottom:16px;">✅</div>
      <a href="/" class="btn-primary">← Back to Home</a>
    </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
