<%- include('partials/nav', { title: 'Track Order', page: 'track' }) %>
<div class="page-banner">
  <h1>Track Your Order</h1>
  <p>Check the status of your garment</p>
  <div class="breadcrumb"><a href="/">Home</a> › Track Order</div>
</div>
<section class="form-section" style="padding:80px 5%;">
  <div style="max-width:600px;margin:0 auto;">
    <div class="form-card">
      <h2 style="font-family:'Playfair Display',serif;font-size:26px;margin-bottom:8px;">Find Your Order</h2>
      <p style="color:var(--text-light);margin-bottom:28px;">Enter your Order ID or registered phone number.</p>
      <form method="POST" action="/track">
        <div class="form-group"><label>Order ID</label><input name="orderId" placeholder="e.g. ORD-001"></div>
        <div style="text-align:center;color:var(--text-light);margin:12px 0;font-size:13px;">— OR —</div>
        <div class="form-group"><label>Phone Number</label><input name="phone" placeholder="e.g. 9876543210"></div>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;padding:14px;font-size:15px;">🔍 Track Order</button>
      </form>
    </div>
    <% if (searched && error) { %>
    <div class="track-result" style="border-color:#f5c6cb;background:#fff8f8;text-align:center;padding:28px;">
      <div style="font-size:40px;margin-bottom:12px;">❌</div>
      <p style="color:#721c24;font-size:15px;"><%= error %></p>
    </div>
    <% } %>
    <% if (order) { %>
    <div class="track-result">
      <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
        <div>
          <div style="font-size:12px;color:var(--text-light);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;">Order ID</div>
          <div style="font-size:20px;font-weight:700;color:var(--gold);"><%= order.id %></div>
        </div>
        <span class="status-badge status-<%= order.status.replace(' ','-') %>"><%= order.status %></span>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
        <div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Customer</div><div style="font-weight:600;"><%= order.customer_name %></div></div>
        <div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Item</div><div style="font-weight:600;"><%= order.item %></div></div>
        <div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Service</div><div><%= order.service %></div></div>
        <div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Order Date</div><div><%= order.order_date %></div></div>
        <% if (order.delivery_date) { %><div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Expected Delivery</div><div style="font-weight:600;color:var(--gold-dark);"><%= order.delivery_date %></div></div><% } %>
        <% if (order.amount) { %><div><div style="font-size:12px;color:var(--text-light);text-transform:uppercase;margin-bottom:4px;">Amount</div><div style="font-weight:600;">₹<%= order.amount %></div></div><% } %>
      </div>
      <% if (order.notes) { %><div style="background:var(--warm);padding:14px 16px;border-radius:10px;font-size:14px;color:var(--text-light);"><strong style="color:var(--text);">Notes:</strong> <%= order.notes %></div><% } %>
      <div style="margin-top:28px;">
        <div style="font-size:12px;color:var(--text-light);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;">Progress</div>
        <% const stages=['Pending','In Progress','Ready','Delivered']; const ci=stages.indexOf(order.status); %>
        <div style="display:flex;">
          <% stages.forEach((s,idx)=>{ %>
          <div style="flex:1;text-align:center;">
            <div style="width:28px;height:28px;border-radius:50%;margin:0 auto 8px;background:<%= idx<=ci?'var(--gold)':'#e5e5e5' %>;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:<%= idx<=ci?'#000':'#999' %>;">
              <%= idx<ci?'✓':idx+1 %>
            </div>
            <div style="font-size:11px;color:<%= idx<=ci?'var(--gold-dark)':'var(--text-light)' %>;font-weight:<%= idx<=ci?'600':'400' %>;"><%= s %></div>
          </div>
          <% }) %>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</section>
<%- include('partials/footer') %>
