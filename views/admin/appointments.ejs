<%- include('partials/sidebar', { pageTitle: 'Appointments', activePage: 'appointments' }) %>
<div class="main">
  <div class="topbar">
    <div class="topbar-title">Appointments</div>
    <div class="topbar-right"><a href="/" target="_blank" class="btn btn-secondary btn-sm">🌐 View Booking Page</a></div>
  </div>
  <div class="content">
    <div class="filter-tabs">
      <a href="/admin/appointments" class="filter-tab <%= !filter?'active':'' %>">All</a>
      <a href="/admin/appointments?status=Pending" class="filter-tab <%= filter==='Pending'?'active':'' %>">Pending</a>
      <a href="/admin/appointments?status=Confirmed" class="filter-tab <%= filter==='Confirmed'?'active':'' %>">Confirmed</a>
      <a href="/admin/appointments?status=Completed" class="filter-tab <%= filter==='Completed'?'active':'' %>">Completed</a>
      <a href="/admin/appointments?status=Cancelled" class="filter-tab <%= filter==='Cancelled'?'active':'' %>">Cancelled</a>
    </div>
    <div class="card">
      <div class="table-wrap"><table>
        <thead><tr><th>Customer</th><th>Phone</th><th>Service</th><th>Date & Time</th><th>Notes</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% appointments.forEach(a => { %>
          <tr>
            <td style="font-weight:600;"><%= a.customer_name %></td>
            <td style="color:var(--text-light);font-size:13px;"><%= a.phone %></td>
            <td style="font-size:13px;"><%= a.service %></td>
            <td>
              <div style="font-weight:600;"><%= a.appt_date %></div>
              <div style="font-size:12px;color:var(--text-light);">⏰ <%= a.appt_time %></div>
            </td>
            <td style="font-size:13px;color:var(--text-light);max-width:180px;"><%= a.notes || '—' %></td>
            <td>
              <form method="POST" action="/admin/appointments/status/<%= a.id %>" style="display:inline;">
                <select name="status" onchange="this.form.submit()" style="font-size:12px;padding:4px 8px;border-radius:6px;border:1px solid var(--border);">
                  <% ['Pending','Confirmed','Completed','Cancelled'].forEach(s => { %>
                  <option value="<%= s %>" <%= a.status===s?'selected':'' %>><%= s %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td>
              <div style="display:flex;gap:6px;">
                <a href="https://wa.me/<%= a.phone %>?text=Hi+<%= encodeURIComponent(a.customer_name) %>%2C+your+appointment+at+Santhosh+Garments+on+<%= a.appt_date %>+at+<%= a.appt_time %>+is+confirmed." target="_blank" class="btn btn-sm btn-success" title="WhatsApp">💬</a>
                <form method="POST" action="/admin/appointments/delete/<%= a.id %>" onsubmit="return confirm('Delete?')">
                  <button class="btn btn-sm btn-danger">🗑</button>
                </form>
              </div>
            </td>
          </tr>
          <% }) %>
          <% if (appointments.length===0) { %>
          <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--text-light);"><div style="font-size:32px;margin-bottom:12px;">📅</div>No appointments found.</td></tr>
          <% } %>
        </tbody>
      </table></div>
    </div>
  </div>
</div>
</body></html>
