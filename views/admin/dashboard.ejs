<%- include('partials/sidebar', { pageTitle: 'Dashboard', activePage: 'dashboard' }) %>
<div class="main">
  <div class="topbar">
    <div class="topbar-title">Dashboard</div>
    <div class="topbar-right">
      <span style="font-size:13px;color:var(--text-light);"><%= new Date().toLocaleDateString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></span>
      <div class="topbar-user"><div class="user-avatar">A</div><span>Admin</span></div>
    </div>
  </div>
  <div class="content">
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-icon gold">📋</div><div class="stat-num"><%= stats.totalOrders %></div><div class="stat-label">Total Orders</div><div class="stat-sub warn"><%= stats.pendingOrders %> pending</div></div>
      <div class="stat-card"><div class="stat-icon blue">⏳</div><div class="stat-num"><%= stats.inProgressOrders %></div><div class="stat-label">In Progress</div><div class="stat-sub"><%= stats.readyOrders %> ready for pickup</div></div>
      <div class="stat-card"><div class="stat-icon green">💰</div><div class="stat-num">₹<%= stats.totalRevenue.toLocaleString('en-IN') %></div><div class="stat-label">Total Revenue</div></div>
      <div class="stat-card"><div class="stat-icon purple">👥</div><div class="stat-num"><%= stats.totalCustomers %></div><div class="stat-label">Customers</div></div>
      <div class="stat-card"><div class="stat-icon blue">📅</div><div class="stat-num"><%= stats.pendingAppointments %></div><div class="stat-label">Pending Appointments</div><div class="stat-sub"><%= stats.todayAppointments %> today</div></div>
      <% if (stats.lowStock > 0) { %>
      <div class="stat-card" style="border-color:#FECACA;"><div class="stat-icon red">⚠️</div><div class="stat-num" style="color:var(--danger);"><%= stats.lowStock %></div><div class="stat-label">Low Stock Fabrics</div><div class="stat-sub" style="color:var(--danger);">Reorder needed</div></div>
      <% } %>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <div class="card">
        <div class="card-header"><span class="card-title">Recent Orders</span><a href="/admin/orders" class="btn btn-sm btn-secondary">View All</a></div>
        <div class="table-wrap"><table>
          <thead><tr><th>Order ID</th><th>Customer</th><th>Item</th><th>Status</th><th>Amount</th></tr></thead>
          <tbody>
            <% recentOrders.forEach(o => { %>
            <tr>
              <td style="font-weight:700;color:var(--gold);">#<%= o.id %></td>
              <td><%= o.customer_name %></td>
              <td style="color:var(--text-light);"><%= o.item %></td>
              <td><span class="badge badge-<%= o.status.toLowerCase().replace(' ','-')==='in-progress'?'progress':o.status.toLowerCase().replace(/\s/g,'-') %>"><%= o.status %></span></td>
              <td style="font-weight:600;">₹<%= o.amount %></td>
            </tr>
            <% }) %>
            <% if (recentOrders.length===0) { %><tr><td colspan="5" style="text-align:center;color:var(--text-light);padding:24px;">No orders yet</td></tr><% } %>
          </tbody>
        </table></div>
      </div>

      <div class="card">
        <div class="card-header"><span class="card-title">Recent Appointments</span><a href="/admin/appointments" class="btn btn-sm btn-secondary">View All</a></div>
        <div class="table-wrap"><table>
          <thead><tr><th>Customer</th><th>Service</th><th>Date</th><th>Status</th></tr></thead>
          <tbody>
            <% appointments.forEach(a => { %>
            <tr>
              <td style="font-weight:600;"><%= a.customer_name %></td>
              <td style="color:var(--text-light);font-size:13px;"><%= a.service %></td>
              <td style="font-size:13px;"><%= a.appt_date %> <span style="color:var(--text-light)"><%= a.appt_time %></span></td>
              <td><span class="badge badge-<%= a.status.toLowerCase() %>"><%= a.status %></span></td>
            </tr>
            <% }) %>
            <% if (appointments.length===0) { %><tr><td colspan="4" style="text-align:center;color:var(--text-light);padding:24px;">No appointments</td></tr><% } %>
          </tbody>
        </table></div>
      </div>
    </div>

    <div class="card" style="margin-top:20px;">
      <div class="card-header"><span class="card-title">Quick Actions</span></div>
      <div class="card-body" style="display:flex;gap:12px;flex-wrap:wrap;">
        <a href="/admin/orders/new" class="btn btn-gold">+ New Order</a>
        <a href="/admin/inventory" class="btn btn-secondary">🧶 Manage Inventory</a>
        <a href="/admin/customers" class="btn btn-secondary">👥 View Customers</a>
        <a href="/admin/gallery" class="btn btn-secondary">🖼️ Update Gallery</a>
        <a href="/admin/settings" class="btn btn-secondary">⚙️ Settings</a>
      </div>
    </div>
  </div>
</div>
</body></html>
