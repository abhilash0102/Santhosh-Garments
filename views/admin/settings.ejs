<%- include('partials/sidebar', { pageTitle: 'Settings', activePage: 'settings' }) %>
<div class="main">
  <div class="topbar"><div class="topbar-title">Shop Settings</div></div>
  <div class="content">
    <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
    <form method="POST" action="/admin/settings">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start;">
        <div>
          <div class="card">
            <div class="card-header"><span class="card-title">Shop Information</span></div>
            <div class="card-body">
              <div class="form-group"><label>Shop Name</label><input name="shopName" value="<%= settings.shop_name %>"></div>
              <div class="form-group"><label>Tagline</label><input name="tagline" value="<%= settings.tagline %>"></div>
              <div class="form-group"><label>Address</label><textarea name="address" rows="2"><%= settings.address %></textarea></div>
              <div class="form-group"><label>Working Hours</label><input name="workingHours" value="<%= settings.working_hours %>"></div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Contact Details</span></div>
            <div class="card-body">
              <div class="form-group"><label>Phone</label><input name="phone" value="<%= settings.phone %>"></div>
              <div class="form-group"><label>WhatsApp Number</label><input name="whatsapp" value="<%= settings.whatsapp || '' %>" placeholder="Without + or spaces"></div>
              <div class="form-group"><label>Email</label><input name="email" type="email" value="<%= settings.email %>"></div>
            </div>
          </div>
        </div>
        <div>
          <div class="card">
            <div class="card-header"><span class="card-title">Social Media</span></div>
            <div class="card-body">
              <div class="form-group"><label>Instagram URL</label><input name="instagram" value="<%= settings.instagram || '' %>" placeholder="https://instagram.com/..."></div>
              <div class="form-group"><label>Facebook URL</label><input name="facebook" value="<%= settings.facebook || '' %>" placeholder="https://facebook.com/..."></div>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><span class="card-title">Admin Credentials</span></div>
            <div class="card-body">
              <div style="background:var(--bg);border-radius:10px;padding:16px;font-size:14px;color:var(--text-light);">
                <p><strong style="color:var(--text);">Username:</strong> admin</p>
                <p style="margin-top:8px;"><strong style="color:var(--text);">Password:</strong> santhosh2025</p>
                <p style="margin-top:12px;font-size:12px;">To change, update the <code>admin_users</code> table in your Supabase dashboard with a new bcrypt hash.</p>
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn-gold" style="width:100%;justify-content:center;padding:14px;font-size:15px;margin-top:4px;">✓ Save All Settings</button>
        </div>
      </div>
    </form>
  </div>
</div>
</body></html>
